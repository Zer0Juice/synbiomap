# Copy this file to .env and fill in your credentials.
# Never commit .env to git.

# OpenAlex does not require an API key, but providing a polite email
# enables the "polite pool" which gives faster responses.
OPENALEX_EMAIL=your.email@example.com

# Lens.org API token (for patent data)
# Sign up at https://www.lens.org/lens/user/subscriptions
LENS_API_TOKEN=your_lens_token_here

# Optional: HuggingFace token (needed if using gated models)
HF_TOKEN=your_huggingface_token_here

# Geocoding provider (default: Nominatim, which is free)
# If using OpenCage: https://opencagedata.com/
OPENCAGE_API_KEY=your_opencage_key_here
