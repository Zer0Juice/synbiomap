# Copy this file to .env and fill in your credentials.
# Never commit .env to git.

# OpenAlex optional credentials.
# - Email: enables the "polite pool" for slightly faster responses.
# - API key: free account at https://openalex.org gives 10,000 filtered
#   queries/day and 1,000 full-text searches/day. Passed as ?api_key=...
OPENALEX_EMAIL=your.email@example.com
OPENALEX_API_KEY=your_openalex_api_key_here

# PatentsView API key (optional — not required for basic access)
# Without a key: 45 requests/minute. With a key: higher rate limit.
# Sign up at https://patentsview.org/apis/keyrequest
PATENTSVIEW_API_KEY=

# Optional: HuggingFace token (needed if using gated models)
HF_TOKEN=your_huggingface_token_here

# Geocoding provider (default: Nominatim, which is free)
# If using OpenCage: https://opencagedata.com/
OPENCAGE_API_KEY=your_opencage_key_here
